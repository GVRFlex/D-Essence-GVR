---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Signature Facials | D-Essence Wellness',
  description:
    'Customized facials using Circadia®, Face Reality®, and SkinMedica® for balanced, hydrated, radiant skin: Seasonal Enzyme, Classic, Hydrospa, Dermaplane, Oxygen, Teen, and Firming Peptide.',
  canonical: 'https://www.d-essencewellness.com/services/signature-facials/',
  type: 'website',

  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: 'Signature Facials',
      serviceType: 'Facials',
      description:
        'Customized facials using Circadia®, Face Reality®, and SkinMedica® to cleanse, exfoliate, hydrate, and brighten for healthy, radiant skin.',
      areaServed: 'Hudson Valley, NY',

      provider: {
        '@type': 'HealthAndBeautyBusiness',
        name: 'D-Essence Wellness',
        url: 'https://www.d-essencewellness.com',
        image: 'https://www.d-essencewellness.com/LOGO_W.webp',
        priceRange: '$$',
        telephone: '+1-716-303-8963',
        address: {
          '@type': 'PostalAddress',
          streetAddress: '871 Blooming Grove Turnpike Suite 102',
          addressLocality: 'New Windsor',
          addressRegion: 'NY',
          postalCode: '12553',
          addressCountry: 'US'
        }
      },

      url: 'https://www.d-essencewellness.com/services/signature-facials/'
    },

    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Services',
          item: 'https://www.d-essencewellness.com/services/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Signature Facials',
          item: 'https://www.d-essencewellness.com/services/signature-facials/'
        }
      ]
    }
  ]
};
---


<BaseLayout seo={seo}>
  <!-- Preload shared service image (swap later) -->
  <link
    rel="preload"
    as="image"
    href="/Signature_Facials.webp"
    imagesrcset="/Signature_Facials.webp 1x, /Signature_Facials.webp 2x"
    imagesizes="(min-width: 1024px) 480px, 64vw"
  />

  <!-- ===== HERO (dark) ===== -->
  <section class="bg-neutral-950 text-white">
    <div class="container pt-28 pb-12">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.18em] text-white/70">
          <span>Facials</span>
          <span class="opacity-60">•</span>
          <span>New Windsor, NY</span>
        </div>

        <h1 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight">Signature Facials</h1>
        <div class="mt-4 h-px w-28 mx-auto bg-gradient-to-r from-transparent via-white to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- ===== MAIN (2 cols) ===== -->
  <section class="relative bg-white text-neutral-900">
    <div class="container py-14 sm:py-[4.5rem]">
      <div class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-10 items-center">
        <!-- Image -->
        <figure class="relative">
          <div class="pointer-events-none absolute -left-6 inset-y-6 w-16 rounded-full bg-gradient-to-r from-neutral-200 to-transparent blur-lg"></div>
          <div class="pointer-events-none absolute -right-6 inset-y-6 w-16 rounded-full bg-gradient-to-l from-neutral-200 to-transparent blur-lg"></div>

          <picture>
            <!-- <source srcset="/Signature_Facials.avif" type="image/avif" /> -->
            <source srcset="/Signature_Facials.webp" type="image/webp" />
            <img
              id="ba-open"
              src="/Signature_Facials.webp"
              alt="Signature Signature Facials at D-Essence Wellness"
              fetchpriority="high"
              decoding="async"
              sizes="(min-width: 1024px) 480px, (min-width: 640px) 60vw, 92vw"
              class="cursor-zoom-in mx-auto w-full max-w-[12rem] sm:max-w-[16rem] md:max-w-[22rem] lg:max-w-[26rem] h-auto rounded-2xl ring-1 ring-neutral-200 shadow-2xl bg-neutral-100"
              width="960"
              height="1280"
              onerror="this.onerror=null; this.src='/placeholder-service.jpg';"
            />
          </picture>
        </figure>

        <!-- Copy + CTA (sin cuadros) -->
        <div>
          <p class="text-neutral-700/90">
            At D-Essence Wellness, every facial is customized to your skin’s needs using advanced formulations from
            <span class="font-medium">Circadia®</span>, <span class="font-medium">Face Reality®</span>, and
            <span class="font-medium">SkinMedica®</span> to deliver balanced, hydrated, and radiant results.
          </p>

          <!-- Facials as paragraphs with bold subheads -->
          <div class="mt-6 space-y-4 text-sm sm:text-base text-neutral-700">
            <p><span class="font-medium text-neutral-900">Circadia Seasonal Enzyme Facial.</span> Gentle enzyme exfoliation with seasonal blends like Pumpkin, Cranberry, or Cocoa to brighten and refresh.</p>
            <p><span class="font-medium text-neutral-900">Classic Facial.</span> Deep cleanse, exfoliation, and hydration—ideal for all skin types.</p>
            <p><span class="font-medium text-neutral-900">Hydrospa Facial.</span> Deeply cleanses, exfoliates, and hydrates using hydro-technology for a fresh, healthy glow.</p>
            <p><span class="font-medium text-neutral-900">Dermaplane Facial.</span> Gently removes dead skin and peach fuzz to reveal a smoother surface and enhance product absorption.</p>
            <p><span class="font-medium text-neutral-900">Oxygen Facial.</span> Infuses oxygen and essential nutrients for instant brightness, hydration, and bounce.</p>
            <p><span class="font-medium text-neutral-900">Teen Facial (Face Reality®).</span> Clears, calms, and educates acne-prone teen skin for long-term clarity and confidence.</p>
            <p><span class="font-medium text-neutral-900">Firming Peptide Facial (Circadia®).</span> Peptide-powered technology visibly firms, smooths, and revitalizes tired or aging skin.</p>
          </div>

          <!-- CTA (solo botón) -->
          <div class="mt-8">
            <a
              href="https://na02.patientnow.com/a/dessencewellness/OnlineBooking.aspx"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center rounded-full bg-neutral-900 text-white px-6 py-3 text-sm font-medium hover:bg-neutral-800 active:bg-neutral-900/90 focus:outline-none focus:ring-2 focus:ring-neutral-300"
              aria-label="Book a Signature Facial"
            >
              Book Now
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox / Zoom -->
    <div
      id="ba-lightbox"
      class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-150"
      role="dialog"
      aria-modal="true"
      aria-labelledby="lb-title"
      aria-describedby="lb-desc"
    >
      <div class="absolute inset-0 bg-black/80"></div>
      <div class="relative h-full w-full flex items-center justify-center p-4">
        <h2 id="lb-title" class="sr-only">Zoomed image</h2>
        <p id="lb-desc" class="sr-only">Press Escape or the close button to exit.</p>

        <picture>
          <!-- <source srcset="/Signature_Facials.avif" type="image/avif" /> -->
          <source srcset="/Signature_Facials.webp" type="image/webp" />
          <img
            src="/Signature_Facials.webp"
            alt="Zoomed image for signature Signature Facials"
            class="max-h-[90vh] max-w-[92vw] rounded-2xl ring-1 ring-white/20 shadow-2xl"
          />
        </picture>

        <button
          id="ba-close"
          class="absolute top-4 right-4 inline-flex items-center justify-center rounded-full bg-white/90 text-neutral-900 h-10 w-10 hover:bg-white focus:outline-none focus:ring-2 focus:ring-white/50"
          aria-label="Close image"
          title="Close"
        >
          ✕
        </button>
      </div>
    </div>
  </section>

  <!-- Lightbox script -->
  <script is:inline>
    (() => {
      const openEl = document.getElementById('ba-open');
      const lightbox = document.getElementById('ba-lightbox');
      const closeEl = document.getElementById('ba-close');

      if (!openEl || !lightbox || !closeEl) return;

      let lastFocused = null;

      function show() {
        lastFocused = document.activeElement;
        lightbox.classList.remove('hidden');
        requestAnimationFrame(() => {
          lightbox.classList.remove('opacity-0');
          lightbox.classList.add('opacity-100');
        });

        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', onKey);
        setTimeout(() => closeEl.focus(), 0);
      }

      function hide() {
        lightbox.classList.add('opacity-0');
        lightbox.classList.remove('opacity-100');
        setTimeout(() => {
          lightbox.classList.add('hidden');
        }, 150);

        document.body.style.overflow = '';
        document.removeEventListener('keydown', onKey);
        if (lastFocused && typeof lastFocused.focus === 'function') {
          lastFocused.focus();
        }
      }

      function onKey(e) {
        if (e.key === 'Escape') hide();
        if (e.key === 'Tab') {
          e.preventDefault();
          closeEl.focus();
        }
      }

      openEl.addEventListener('click', show);
      closeEl.addEventListener('click', hide);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) hide();
      });
    })();
  </script>
</BaseLayout>
